# LLM for answers, reranking, evaluation, and optional LLM chunk preprocessing.
# Default: local Ollama (free). Set LLM_PROVIDER=openai to use OpenAI instead.
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OPENAI_MODEL=gpt-4.1-nano
OPENAI_API_KEY=

# Embeddings use HuggingFace all-MiniLM-L6-v2 locally (no API key required).
EMBEDDING_MODEL=all-MiniLM-L6-v2
